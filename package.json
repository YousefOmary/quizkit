{
  "name": "atlas-sprint",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/tests/*.test.js",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:ios": "npm run cap:sync && cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "@fontsource-variable/atkinson-hyperlegible-next": "^5.3.0",
    "@fontsource-variable/bricolage-grotesque": "^5.3.0",
    "flag-icons": "^7.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "world-countries": "^5.1.0"
  }
}
